{
  "name": "@minimal-kit/starter-vite-ts",
  "author": "Minimals",
  "version": "6.0.1",
  "description": "Vite Starter & TypeScript",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "dev:local": "vite --mode local",
    "dev:stage": "vite --mode staging",
    "dev:prod": "vite --mode production",
    "start": "vite preview",
    "build": "node csp/buildCSP.js development && tsc && vite build --mode development",
    "build:dev": "node csp/buildCSP.js development && tsc && vite build --mode development",
    "build:stage": "node csp/buildCSP.js staging && tsc && vite build --mode staging",
    "build:prod": "node csp/buildCSP.js production && tsc && vite build --mode production",
    "preview:dev": "vite preview --mode development",
    "preview:stage": "vite preview --mode staging",
    "preview:prod": "vite preview --mode production",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "rm:all": "rm -rf node_modules .next out dist build",
    "re:start": "yarn rm:all && yarn install && yarn dev",
    "re:build": "yarn rm:all && yarn install && yarn build",
    "re:build-npm": "npm run rm:all && npm install && npm run build",
    "dev:host": "vite --host --mode development",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
