<!DOCTYPE html>
<html lang="en">

<head>
  <!-- Required meta tags -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Voucher Application Form</title>
  <link rel="icon" href="data:,">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet" />

  <style type="text/css">
    body {
      margin: 0;
      font-family: "Poppins", serif;
    }

    .wrapper {
      background: white;
      max-width: 1299px;
      font-family: "Poppins", serif;
      font-weight: 400;
      font-style: normal;
      margin: 0px auto;
      position: relative;
    }

    .header-logo-wrap {
      background: #1a407d;
      margin-bottom: 36px;
    }

    .header-logo-box {
      max-width: 1299px;
      margin: 0px auto;
      padding-top: 24px;
      padding-bottom: 24px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-title {
      font-size: 24px;
      font-weight: 600;
      color: #fff;
    }

    .header-logo {
      position: absolute;
      top: 24px;
      right: 15px;
      width: 276px;
      height: 32px;
      text-align: right;
    }

    .header-logo img {
      max-width: 85%;
      max-height: 100%;
    }

    .applicant-details-card {
      margin: 10px 15px;
      padding: 24px 24px;
      border: 1px solid rgba(26, 64, 125, 0.3);
      border-radius: 8px;
      margin-bottom: 18px;
    }

    .kyc-details-card {
      margin: 10px 15px;
      padding: 24px 24px;
      border: 1px solid rgba(26, 64, 125, 0.3);
      border-radius: 8px;
      margin-bottom: 18px;
      min-height: 700px;
    }

    .payment-details-card {
      margin: 10px 15px;
      padding: 24px 24px;
      border: 1px solid rgba(26, 64, 125, 0.3);
      border-radius: 8px;
      margin-bottom: 18px;
      min-height: 700px;
    }

    .position-relative {
      position: relative;
    }

    .position-absolute {
      position: absolute;
    }

    .padding24 {
      padding: 24px;
    }

    .d-flex {
      display: flex;
    }

    .d-block {
      display: block;
    }

    .line-dotted {
      border-bottom: 2px dashed #d6d6d6;
