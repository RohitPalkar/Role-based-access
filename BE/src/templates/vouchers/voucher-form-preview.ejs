<body>
  <div class="header-logo-wrap">
    <div class="header-logo-box">
      <div class="header-title">
        <%- voucher?.formPhase == voucherFormType.VOUCHER ? 'Voucher Form' : 'Expression Of Interest'; %>
      </div>
      <div class="header-logo">
        <img src="<%= IMAGE_BASE_URL%><%= termsCondition?.logoImage %>" alt="" />
      </div>
    </div>
  </div>
  <div class="wrapper applicantDetailsCard">
    <%
      VOUCHER_DATE_FORMAT="DD-MMM-YYYY";
      primarySource=voucher?.primarySource ?? '';


      // Helper to print 1st/2nd/3rd/4th... const
      ordinal=(n)=> {
        const suffixes = { 1: 'st', 2: 'nd', 3: 'rd' };
        const v = n % 100;
        const suffix = suffixes[v] && v % 10 === v ? suffixes[v] : 'th';
        const label = `${n}<sup>${suffix}</sup> Applicant`;
        return label;
      };
    %>
      <div class="customer-details-card">
        <div class="contentWrap">
          <%
            const primaryApplicant = voucher?.applicant1 ?? {};
            const formPhase = voucher?.formPhase ?? voucherFormType.VOUCHER;
          %>
          <div class="d-flex marginBottom16 align-items-start" style="justify-content: space-between;">
            <!-- LEFT SIDE -->
            <div style="width: 60%; display: flex; flex-direction: column; gap: 15px; align-items: flex-start;">
              <h5>
                <span> Customer Name:</span>
                <%=primaryApplicant?.personalDetails?.firstName ?? ''%>
                <%=primaryApplicant?.personalDetails?.lastName ?? ''%>
              </h5>
          
              <h5>
                <span> Mobile Number:</span>
                <%=primaryApplicant?.personalDetails?.countryCode ?? ''%>
                <%=primaryApplicant?.personalDetails?.contactNumber ?? ''%>
              </h5>
          
              <div class="skyBlueBg">
                Payment Ref ID: <%= voucher?.uniqueReferenceId %>
              </div>
          
              <% if(voucher?.paidVoucherId) { %>
                <div class="skyBlueBg">
                  Voucher ID: <%= voucher?.paidVoucherId %>
                </div>
              <% } %>
              <% if(voucher?.stdEoiId) { %>
                <div class="skyBlueBg">
                  Standard EOI ID: <%= voucher?.stdEoiId %>
                </div>
              <% } %>
              <% if(voucher?.preEoiId) { %>
                <div class="skyBlueBg">
                  Preferential EOI ID: <%= voucher?.preEoiId %>
                </div>
              <% } %>
          
              <div class="orangeBtn">
                Status: <%= voucher?.voucherFormStatus %>
              </div>
          
              <div class="purpleBtn">
                Preferred Typology: <%= voucher?.eoiDetails?.typology %>
              </div>
          
            </div>
          
            <!-- RIGHT SIDE -->
            <div style="width: 40%; display: flex; flex-direction: column; gap: 20px; align-items: flex-end; text-align: right;">
              <h5>
                <span>Initiated Date:</span>
                <%= voucher?.createdAt ? formatDate(voucher?.createdAt, VOUCHER_DATE_FORMAT) : '-' %>
              </h5>

              <h5>
                <%
                  if((formPhase === voucherFormType.VOUCHER) ||
                  (formPhase === voucherFormType.EOI &&
                  voucher?.voucherIssuedAt)) {
                %>
                <span> Voucher ID Issued:</span>
                <%- voucher?.voucherIssuedAt ? formatDate(voucher?.voucherIssuedAt, VOUCHER_DATE_FORMAT) : '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;-&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;'%>
                <% } %>
              </h5>
                <% if (formPhase === voucherFormType.EOI) { %>
                <% if (voucher?.stdEoiIssuedAt) { %>
              <h5>
                <span>Standard EOI ID Issued:</span>
                <%= formatDate(voucher.stdEoiIssuedAt, VOUCHER_DATE_FORMAT) %>
              </h5>
                <% } %>
                <% if (voucher?.preEoiIssuedAt) { %>
              <h5>
                <span>Preferential EOI ID Issued:</span>
                <%= formatDate(voucher.preEoiIssuedAt, VOUCHER_DATE_FORMAT) %>
                </h5>
                <% } %>
                <% } %>
              <h5><span> Primary Source:</span> <%= voucher?.primarySource %></h5>
          
              <% if(voucher?.sourceDetails?.channelPartner) { %>
                <h5><span> Channel Partner Name:</span> <%= voucher?.sourceDetails?.channelPartner %></h5>
              <% } else { %>
                <% if(voucher?.sourcingRm) { %>
                  <h5><span> Sourcing RM:</span> <%= voucher?.sourcingRm %></h5>
                <% } else if(voucher?.closingRm) { %>
                  <h5><span> Closing RM:</span> <%= voucher?.closingRm %></h5>
                <% } %>
              <% } %>

              <% if(voucher?.sourceDetails?.channelPartner && voucher?.sourcingRm) { %>
                <h5><span> Sourcing RM:</span> <%= voucher?.sourcingRm %></h5>
              <% } else if(voucher?.sourceDetails?.channelPartner && !voucher?.sourcingRm && voucher?.closingRm) { %>
                <h5><span> Closing RM:</span> <%= voucher?.closingRm %></h5>
              <% } else if(!voucher?.sourceDetails?.channelPartner && voucher?.sourcingRm && voucher?.closingRm) { %>
                <h5><span> Closing RM:</span> <%= voucher?.closingRm %></h5>
              <% } %>


              <% if(voucher?.sourceDetails?.channelPartner && voucher?.sourcingRm && voucher?.closingRm) { %>
                <h5><span> Closing RM:</span> <%= voucher?.closingRm %></h5>
              <% } %>
            </div>
          </div>
          <ul class="amountList">
            <li>
              <div class="skyBlueBox"></div>
              <h3>₹ <%= formatIndianAmount(voucher?.paymentDetails?.amountPayable) %></h3>
              <p>EOI Amount</p>
            </li>
            <li>
              <div class="greenBox"></div>
              <h3>₹ <%= formatIndianAmount(voucher?.paymentDetails?.totalAmountPaid) %></h3>
              <p>Amount Paid</p>
            </li>
            <li>
              <div class="lightOrangeBox"></div>
              <h3>₹ <%= formatIndianAmount(Math.max(0, (voucher?.paymentDetails?.amountPayable || 0) - (voucher?.paymentDetails?.totalAmountPaid || 0))) %></h3>
              <p>Balance Due</p>
            </li>
          </ul>
          </ul>
        </div>
      </div>

      <%- include('partials/payment-details', {
        paymentDetails: voucher?.paymentDetails,
        payments: voucher?.payments,
        pageBreak: false
      }); %>

      <!-- Render General Details -->
      <%- include('partials/applicant', {
        applicant: voucher?.applicant1,
        label: "Primary Applicant",
        isPrimaryApplicant: true,
        pageBreak: true
      }); %>
      <% if(voucher?.applicant2) { %>
        <%- include('partials/applicant', {
          applicant: voucher?.applicant2,
          label: ordinal(2),
          isPrimaryApplicant: false,
          pageBreak: true
        });%>
      <% } %>
      <% if(voucher?.applicant3) { %>
        <%- include('partials/third-applicant', {
          applicant: voucher?.applicant3,
          label: ordinal(3),
          isPrimaryApplicant: false,
          pageBreak: true
        }); %>
      <% } %>
      <% if(voucher?.applicant4) { %>
        <%- include('partials/third-applicant', {
          applicant: voucher?.applicant4,
          label: ordinal(4),
          isPrimaryApplicant: false,
          pageBreak: false
        }); %>
      <% } %>

      <!-- 5 -->
      <div class="kyc-documents page-break">
        <div class="kyc-applicant-1">
          <%- include('partials/kyc-details', {
            kycDetails: voucher?.applicant1?.contactDetails,
            label: "Primary Applicant",
            pageBreak: false
          }) %>
        </div>

        <% if (voucher?.applicant2) { %>
          <div class="kyc-applicant-2 page-break">
            <%- include('partials/kyc-details', {
              kycDetails: voucher?.applicant2?.contactDetails,
              label: ordinal(2),
              pageBreak: false
            }) %>
          </div>
        <% } %>
      <!-- 5 -->
      <!-- 6 -->
       <% if(['Purva Privilege','Provident Premier'].includes(primarySource)) { %>
        <%- include('partials/referrer-details', {
          sourceDetails: voucher?.sourceDetails,
          primarySource: primarySource,
          secondarySource: voucher?.secondarySource ?? null,
          pageBreak: true
        }); %>
      <% } %>
      <!-- 6 -->
      <%- include('partials/refund-details', {
        refundDetails: voucher?.paymentDetails?.recoveryAccountDetails,
        pageBreak: true
      }); %>

      <div class="terms-wrapper page-break">
        <div class="terms-condition">
          <div class="applicant-details-card">
            <h3 class="title-personal-hd marginBottom16">Terms and Conditions</h3>
            <%- voucher?.termsAndCondition;%>
          </div>
        </div>
      </div>
  </div>
</body>

</html>